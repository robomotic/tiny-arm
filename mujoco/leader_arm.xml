<mujoco model="leader_arm">
    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="512" height="512"/>
        <material name="floor_mat" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0.2"/>
    </asset>

    <default>
        <joint armature="1" damping="1" limited="true"/>
        <geom conaffinity="0" condim="3" density="5.0" friction="1 0.5 0.5" margin="0.001" rgba="0.8 0.2 0.2 1"/>
        <position kp="1"/>
    </default>

    <worldbody>
        <!-- Environment -->
        <light dir="-0 0 -1" pos="0 0 1.5" castshadow="false"/>
        <geom name="floor" type="plane" size="0.4 0.4 0.1" material="floor_mat" rgba="1 1 1 1" pos="0 0 -0.01"/>

        <!-- World Frame XYZ: Z is UP, X is FORWARD, Y is LEFT -->
        <body name="l_base" pos="0 0 0">
            <!-- J1 aligns with Z -->
            <geom name="l_base_geom" type="cylinder" size="0.03 0.01"/>
            <joint name="l_joint1" type="hinge" axis="0 0 1" range="-170 170"/>
            
            <body name="l_shoulder" pos="0 0 0.02">
                <!-- J2 aligns with Y (Pitch) -->
                <geom name="l_shoulder_geom" type="box" size="0.015 0.015 0.02" pos="0 0 0"/>
                <joint name="l_joint2" type="hinge" axis="0 1 0" range="-90 90"/>
                
                <body name="l_upper_arm" pos="0 0 0">
                    <!-- L1 = 12cm -->
                    <geom name="l_upper_arm_geom" type="cylinder" size="0.005 0.06" rgba="1 0.5 0.5 1" pos="0 0 0.06"/>
                    
                    <body name="l_elbow" pos="0 0 0.12">
                        <!-- J3 aligns with Y (Pitch) -->
                        <geom name="l_elbow_geom" type="box" size="0.015 0.015 0.01" pos="0 0 0"/>
                        <joint name="l_joint3" type="hinge" axis="0 1 0" range="-120 120"/>
                        
                        <body name="l_forearm" pos="0 0 0">
                            <!-- L2 = 12cm -->
                            <geom name="l_forearm_geom" type="cylinder" size="0.005 0.06" rgba="1 0.5 0.5 1" pos="0 0 0.06"/>
                            
                            <body name="l_wrist_pitch" pos="0 0 0.12">
                                <!-- J4 aligns with Y (Pitch) -->
                                <geom name="l_wrist_geom" type="box" size="0.01 0.01 0.01" pos="0 0 0"/>
                                <joint name="l_joint4" type="hinge" axis="0 1 0" range="-90 90"/>
                                
                                <body name="l_wrist_roll" pos="0 0 0.015">
                                    <!-- J5 aligns with Z (Roll) -->
                                    <geom name="l_wrist_roll_geom" type="box" size="0.01 0.01 0.01"/>
                                    <joint name="l_joint5" type="hinge" axis="0 0 1" range="-170 170"/>
                                    
                                    <body name="l_trigger_handle" pos="0 0 0.01">
                                        <!-- Remote actuation handle -->
                                        <geom name="l_handle" type="box" size="0.01 0.02 0.005" rgba="0.3 0.3 0.3 1"/>
                                        <body name="l_trigger_finger" pos="0 0.01 0.01">
                                            <!-- Simple trigger hinge for operator to pull -->
                                            <geom name="l_trigger_geom" type="box" size="0.005 0.01 0.002" rgba="0.5 0.1 0.1 1"/>
                                            <joint name="l_joint6_trigger" type="hinge" axis="1 0 0" range="0 30"/>
                                        </body>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <!-- In the real world, leader arm is mostly passive, but we define actuators for sim tests -->
        <position name="l_motor1" joint="l_joint1"/>
        <position name="l_motor2" joint="l_joint2"/>
        <position name="l_motor3" joint="l_joint3"/>
        <position name="l_motor4" joint="l_joint4"/>
        <position name="l_motor5" joint="l_joint5"/>
        <position name="l_motor6" joint="l_joint6_trigger"/>
    </actuator>
</mujoco>
