<mujoco model="tinyarm_scene">
    <include file="follower_arm.xml"/>
    <include file="leader_arm.xml"/>

    <statistic extent="0.5" center="0 0 0.1"/>
    
    <visual>
        <headlight ambient=".4 .4 .4" diffuse=".8 .8 .8" specular="0.1 0.1 0.1"/>
        <map znear=".01"/>
        <quality shadowsize="2048"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="texplane" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .2 .3" type="2d" width="512" height="512"/>
        <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="1 1" texuniform="true"/>
    </asset>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" specular=".2 .2 .2" pos="0 0 5" dir="0 0 -1"/>
        <geom name="floor" pos="0 0 0" size="0 0 .25" type="plane" material="matplane"/>
        
        <!-- Position the arms in the scene -->
        <body name="follower_container" pos="-0.2 0 0">
            <include file="follower_arm.xml"/>
        </body>
        
        <body name="leader_container" pos="0.2 0 0">
            <include file="leader_arm.xml"/>
        </body>
    </worldbody>
</mujoco>
